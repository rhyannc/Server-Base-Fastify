// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum Status {
  ACTIVE
  FROZEN
  ARCHIVED
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  EXPIRED
}

enum UsageMetric {
  COMPANIES
  COLLABORATORS
  INVOICES
}

model User {
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  phone            String?
  passwordHash     String
  avatar           String?
  active           Boolean           @default(true)
  role             Role              @default(MEMBER) //ADMIN DO SISTEMA GLOBAL SAAS
  lastLoginAt      DateTime? // Último login
  chosePlan        Boolean           @default(false)
  createdBy        String? // Usuário que criou
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  userSubscription UserSubscription?
  collaborators    Collaborator[]
  companies        Company[]
  usages           Usage[]

  @@map("users")
}

model Company {
  id         String   @id @default(uuid())
  name       String
  cnpj       String?  @unique
  email      String?
  phone      String?
  country    String?  @default("BR")
  city       String?
  state      String?
  address    String?
  number     String?
  complement String?
  cep        String?
  active     Boolean  @default(true)
  status     Status   @default(ACTIVE) // active, frozen, archived
  createdBy  String?
  createdAt  DateTime @default(now())
  updatedBy  String?
  updatedAt  DateTime @updatedAt

  manager       User           @relation(fields: [managerId], references: [id])
  managerId     String
  collaborators Collaborator[]

  @@map("companies")
}

model Collaborator {
  id        String  @id @default(uuid())
  company   Company @relation(fields: [companyId], references: [id])
  companyId String

  user   User   @relation(fields: [userId], references: [id])
  userId String

  role Role @default(MEMBER)

  active Boolean @default(true)
  status Status  @default(ACTIVE) // active, frozen, archived

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, userId]) // Um usuário só pode ser colaborador de uma empresa uma vez
  @@map("collaborators")
}

model Plan {
  id                String             @id @default(uuid())
  name              String
  description       String?
  isActive          Boolean            @default(true) // Plano ativo/inativo
  isPopular         Boolean            @default(false)
  price             Decimal            @db.Decimal(10, 2)
  maxCompanies      Int?
  maxCollaborators  Int?
  maxInvoices       Int?
  createdAt         DateTime           @default(now())
  userSubscriptions UserSubscription[]

  @@map("plans")
}

model UserSubscription {
  id                Int                @id @default(autoincrement())
  user              User               @relation(fields: [userId], references: [id])
  userId            String             @unique
  plan              Plan               @relation(fields: [planId], references: [id])
  planId            String
  status            SubscriptionStatus // active, trialing, past_due, canceled, expired
  startedAt         DateTime           @default(now()) // Data de início da assinatura
  expiresAt         DateTime? // Data de expiração da assinatura
  trialEndsAt       DateTime? // Data de expiração do período de teste
  canceledAt        DateTime? // Data de cancelamento da assinatura
  gracePeriodEndsAt DateTime? // Data de expiração do período de carência

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_subscriptions")
}

model Usage {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  metric UsageMetric
  value  Int         @default(0)

  period DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, metric, period])
  @@map("usages")
}

model rental_item {
  id          String  @id @default(ulid())
  title       String
  description String?
  latitude    Decimal
  longitude   Decimal

  @@map("rental_items")
}
